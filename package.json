{
  "name": "vana-data-app-starter",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "engines": {
    "node": ">=22.0.0"
  },
  "packageManager": "pnpm@10.6.1",
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "smoke:moksha": "tsx --env-file-if-exists=.env.local scripts/smoke-moksha.ts",
    "test": "tsx --test test/*.test.ts",
    "typecheck": "next typegen && tsc --noEmit",
    "registry:build": "shadcn build --output public/r"
  },
  "dependencies": {
    "@opendatalabs/vana-sdk": "^3.13.4",
    "next": "16.2.10",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "server-only": "0.0.1",
    "viem": "^2.52.2"
  },
  "devDependencies": {
    "@types/node": "^25.0.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "shadcn": "^4.13.0",
    "tsx": "^4.21.0",
    "typescript": "^5.9.0"
  }
}
